---
interface Props {
    nombre: string;
    precio: string;
    descripcion: string;
}

const { nombre, precio, descripcion } = Astro.props;
---

<div class="border border-zinc-800 p-8 hover:border-gold-500 transition-all group bg-zinc-900/30 backdrop-blur-sm">
    <div class="flex justify-between items-start mb-4">
        <h3 class="text-xl font-bold text-white uppercase tracking-wider group-hover:text-gold-500 transition-colors">{nombre}</h3>
        <span class="text-gold-500 font-bold tracking-tighter">{precio}</span>
    </div>
    <p class="text-zinc-500 text-sm leading-relaxed">{descripcion}</p>
</div>