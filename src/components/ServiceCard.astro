---
interface Props {
    nombre: string;
    precio: string;
    descripcion: string;
}

const { nombre, precio, descripcion } = Astro.props;
---

<div class="relative overflow-hidden border border-white/5 p-8 transition-all duration-500 group bg-zinc-900/20 backdrop-blur-md hover:bg-zinc-800/40 hover:border-amber-500/40 shadow-2xl h-full">
    <!-- Efecto de brillo -->
    <div class="absolute -top-24 -right-24 w-48 h-48 bg-amber-500/10 blur-[80px] group-hover:bg-amber-500/20 transition-all duration-700"></div>
    
    <div class="relative z-10 flex flex-col h-full">
        <!-- Contenedor de Título y Precio alineado -->
        <div class="flex justify-between items-baseline mb-6 gap-4">
            <h3 class="text-lg md:text-xl font-bold text-white uppercase tracking-[0.15em] group-hover:text-amber-400 transition-colors duration-500 leading-tight">
                {nombre}
            </h3>
            <div class="flex flex-col items-end flex-shrink-0">
                <span class="text-amber-500 font-black text-2xl tracking-tighter whitespace-nowrap drop-shadow-[0_0_10px_rgba(245,158,11,0.3)]">
                    {precio}
                </span>
                <div class="w-8 h-[2px] bg-amber-500/50 mt-1 group-hover:w-full transition-all duration-700"></div>
            </div>
        </div>
        
        <p class="text-zinc-400 text-sm leading-relaxed font-light group-hover:text-zinc-200 transition-colors duration-500 italic flex-grow">
            {descripcion}
        </p>
        
        <div class="mt-8 flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-700">
            <span class="text-[10px] text-amber-500 uppercase tracking-[0.3em] font-bold">Reserva Exclusiva</span>
            <div class="h-px flex-1 bg-gradient-to-r from-amber-500/50 to-transparent"></div>
        </div>
    </div>
</div>