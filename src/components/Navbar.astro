---
---
<nav id="main-nav" class="fixed w-full z-50 bg-black/40 backdrop-blur-xl border-b border-white/5 px-6 py-5 flex justify-between items-center transition-all duration-500">
    <!-- Logo con nueva jerarquía -->
    <a href="#inicio" class="flex flex-col group cursor-pointer">
        <span class="text-white group-hover:text-amber-500 font-black text-2xl tracking-[0.25em] leading-none transition-colors duration-500">PORTOFINO</span>
        <div class="flex items-center gap-2">
            <div class="h-px w-4 bg-amber-500"></div>
            <span class="text-[9px] text-amber-500/80 tracking-[0.4em] uppercase font-bold">Barber Studio</span>
        </div>
    </a>
    
    <!-- Navegación con indicadores animados -->
    <div class="hidden md:flex gap-8 text-[11px] font-bold uppercase tracking-[0.3em] text-zinc-400">
        <a href="#inicio" class="relative group hover:text-white transition-colors">
            Inicio
            <span class="absolute -bottom-1 left-0 w-0 h-px bg-amber-500 group-hover:w-full transition-all duration-500"></span>
        </a>
        <a href="#servicios" class="relative group hover:text-white transition-colors">
            Servicios
            <span class="absolute -bottom-1 left-0 w-0 h-px bg-amber-500 group-hover:w-full transition-all duration-500"></span>
        </a>
        <!-- Nuevo: Enlace al Club -->
        <a href="#club" class="relative group hover:text-white transition-colors">
            Club
            <span class="absolute -bottom-1 left-0 w-0 h-px bg-amber-500 group-hover:w-full transition-all duration-500"></span>
        </a>
        <!-- Nuevo: Enlace a la Tienda -->
        <a href="#productos" class="relative group hover:text-white transition-colors">
            Store
            <span class="absolute -bottom-1 left-0 w-0 h-px bg-amber-500 group-hover:w-full transition-all duration-500"></span>
        </a>
        <a href="#galeria" class="relative group hover:text-white transition-colors">
            Galería
            <span class="absolute -bottom-1 left-0 w-0 h-px bg-amber-500 group-hover:w-full transition-all duration-500"></span>
        </a>
    </div>

    <!-- Botón de Reserva Estilo "Concierge" -->
    <a href="https://wa.me/51930667583?text=Hola%20PortoFino,%20quisiera%20reservar%20una%20cita" 
       target="_blank" 
       class="relative overflow-hidden group bg-transparent border border-amber-500/50 text-amber-500 px-8 py-3 rounded-none text-[10px] font-black tracking-[0.2em] transition-all duration-500 hover:text-black">
        <span class="relative z-10">RESERVAR CITA</span>
        <div class="absolute inset-0 bg-amber-500 translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
    </a>
</nav>

<script>
    // Cambio de estilo al hacer scroll
    const nav = document.querySelector('#main-nav');
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            nav?.classList.add('bg-black/90', 'py-4', 'border-amber-500/20');
            nav?.classList.remove('bg-black/40', 'py-5', 'border-white/5');
        } else {
            nav?.classList.add('bg-black/40', 'py-5', 'border-white/5');
            nav?.classList.remove('bg-black/90', 'py-4', 'border-amber-500/20');
        }
    });
</script>