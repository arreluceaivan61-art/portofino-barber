---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import MembershipCard from '../components/MembershipCard.astro';
import ProductCard from '../components/ProductCard.astro';
import Footer from '../components/Footer.astro'; 
---

<Layout title="PortoFino Barber Studio | Surquillo">
	<Navbar />
	
	<main class="bg-black font-sans overflow-x-hidden">
		<!-- Hero Section -->
		<section id="inicio" class="relative h-screen flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-b from-black/90 via-black/40 to-black z-[2]"></div>
			<div id="hero-bg" class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1585747860715-2ba37e788b70?q=80&w=1920')] bg-cover bg-center opacity-60 z-[1] will-change-transform scale-105"></div>
			
			<div class="relative z-10 text-center px-6 reveal w-full max-w-full">
				<h2 class="text-amber-400 text-[10px] md:text-sm tracking-[0.3em] uppercase mb-6 font-title font-bold">Bienvenido a la excelencia</h2>
				
				<!-- Ajuste de tamaño responsivo para evitar que sobresalga en móvil -->
				<h1 class="text-[12vw] md:text-[8rem] lg:text-[10rem] font-title font-bold mb-8 tracking-tighter text-white uppercase leading-[0.9]">
					Estilo que <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-200 via-amber-500 to-amber-200 font-accent italic">define.</span>
				</h1>
				
				<div class="w-20 md:w-32 h-px bg-amber-500/50 mx-auto mb-8"></div>
				
				<p class="text-zinc-300 max-w-2xl mx-auto text-base md:text-xl lg:text-2xl mb-10 font-sans font-light leading-relaxed">
					Transformamos tu imagen con técnicas tradicionales en el corazón de <span class="text-white font-semibold border-b border-amber-500/50">Surquillo</span>.
				</p>
				
				<div class="flex justify-center">
					<a href="#servicios" class="group relative overflow-hidden border-2 border-amber-500/50 text-white px-10 py-4 md:px-16 md:py-6 transition-all uppercase text-[10px] md:text-xs tracking-widest font-sans font-black">
						<span class="relative z-10 group-hover:text-black transition-colors duration-300">Explorar Servicios</span>
						<div class="absolute inset-0 bg-amber-500 translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
					</a>
				</div>
			</div>
		</section>

		<!-- Frase de Autor -->
		<section class="py-20 md:py-28 bg-black text-center px-6 border-y border-white/5">
			<div class="max-w-5xl mx-auto reveal">
				<span class="text-amber-500/20 text-6xl md:text-8xl font-accent italic">“</span>
				<p class="text-xl md:text-4xl lg:text-5xl font-accent italic text-zinc-400 -mt-8 md:-mt-12 leading-tight">
					En PortoFino, <span class="text-zinc-100 not-italic font-title text-lg md:text-2xl lg:text-3xl uppercase tracking-[0.15em] block mt-6">esculpimos tu identidad</span>
				</p>
			</div>
		</section>

		<!-- Secciones de Contenido (Servicios, Club, Store) -->
		<!-- Aplicamos el mismo patrón de títulos escalables -->
		<section id="servicios" class="py-24 md:py-40 px-6 bg-[#050505]">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-16 md:mb-28 reveal">
					<h2 class="text-amber-500 tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 font-title font-bold">Nuestra Carta</h2>
					<h3 class="text-[10vw] md:text-7xl lg:text-8xl font-title font-bold text-white uppercase tracking-tight leading-none">Experiencia <span class="font-accent italic font-light lowercase text-amber-200/40">Premium</span></h3>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
					<ServiceCard nombre="Corte de Autor" precio="S/ 50" descripcion="Asesoría de imagen personalizada, lavado premium y acabado con productos de alta gama." />
					<ServiceCard nombre="Ritual de Barba" precio="S/ 35" descripcion="Toallas calientes, aceites esenciales y perfilado con navaja para un acabado impecable." />
					<ServiceCard nombre="PortoFino Combo" precio="S/ 75" descripcion="Experiencia completa: Corte de autor + Ritual de barba con hidratación facial de cortesía." />
				</div>
			</div>
		</section>

		<section id="club" class="py-24 md:py-40 px-6 bg-black">
			<div class="max-w-7xl mx-auto">
				<div class="text-center mb-16 reveal">
					<h2 class="text-amber-500 tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 font-title font-bold">Fidelidad</h2>
					<h3 class="text-[10vw] md:text-7xl lg:text-8xl font-title font-bold text-white uppercase tracking-tight leading-none">Membresía <span class="font-accent italic font-light lowercase text-amber-200/40">Elite</span></h3>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-10">
					<MembershipCard plan="Silver" precio="S/ 120" beneficios={["2 Cortes al mes", "Lavado premium"]} />
					<MembershipCard plan="Gold" precio="S/ 180" popular={true} beneficios={["Cortes ilimitados", "Bebida de cortesía"]} />
					<MembershipCard plan="Black" precio="S/ 250" beneficios={["Acceso total VIP", "Kit bienvenida"]} />
				</div>
			</div>
		</section>

		<!-- Sección de Citas -->
		<section id="citas" class="py-24 md:py-44 bg-[#050505] text-center px-6 relative overflow-hidden">
			<div class="max-w-4xl mx-auto relative z-10 reveal">
				<h2 class="text-amber-500 tracking-[0.3em] uppercase text-[10px] md:text-xs mb-4 font-title font-bold">Disponibilidad</h2>
				<h3 class="text-[10vw] md:text-7xl lg:text-8xl font-title font-bold text-white uppercase mb-10 tracking-tight leading-none">Reserva tu <span class="font-accent italic font-light lowercase text-amber-200/40">Turno</span></h3>
				<p class="text-zinc-400 text-base md:text-xl lg:text-2xl mb-12 font-sans font-light">
					Asegura tu espacio y evita esperas.
				</p>
				<a href="https://wa.me/51930667583" target="_blank" class="inline-block group relative px-10 py-5 md:px-20 md:py-7 bg-amber-500 text-black font-black uppercase text-xs md:text-sm tracking-widest overflow-hidden transition-all duration-300 font-sans">
					<span class="relative z-10 group-hover:text-white transition-colors duration-300">Agendar WhatsApp</span>
					<div class="absolute inset-0 bg-black translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
				</a>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<script>
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) entry.target.classList.add('active');
		});
	}, { threshold: 0.1 });
	document.querySelectorAll('.reveal, .reveal-step').forEach(el => observer.observe(el));
</script>

<style is:global>
	@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@200;400;700;900&family=Playfair+Display:ital,wght@1,400&display=swap');

	:root {
		--font-title: 'Cinzel', serif;
		--font-accent: 'Playfair Display', serif;
		--font-sans: 'Montserrat', sans-serif;
	}

	.font-title { font-family: var(--font-title) !important; }
	.font-accent { font-family: var(--font-accent) !important; }
	.font-sans { font-family: var(--font-sans) !important; }

	.reveal { opacity: 0; transform: translateY(20px); transition: all 1s ease-out; }
	.reveal.active { opacity: 1; transform: translateY(0); }
</style>