---
interface Props {
    plan: string;
    precio: string;
    beneficios: string[];
    popular?: boolean;
}
const { plan, precio, beneficios, popular } = Astro.props;
---
<div class={`relative p-8 border ${popular ? 'border-amber-500 bg-amber-500/5' : 'border-white/10 bg-zinc-900/40'} backdrop-blur-xl transition-all duration-500 group overflow-hidden`}>
    {popular && <span class="absolute top-0 right-0 bg-amber-500 text-black text-[8px] font-bold px-3 py-1 uppercase tracking-widest">Recomendado</span>}
    <h4 class="text-xs tracking-[0.4em] text-amber-500 uppercase mb-2">{plan}</h4>
    <div class="flex items-baseline gap-1 mb-6">
        <span class="text-4xl font-bold text-white">{precio}</span>
        <span class="text-zinc-500 text-xs">/mes</span>
    </div>
    <ul class="space-y-4 mb-8">
        {beneficios.map((item) => (
            <li class="text-zinc-400 text-xs flex items-center gap-3">
                <span class="w-1 h-1 bg-amber-500 rounded-full"></span> {item}
            </li>
        ))}
    </ul>
    <button class="w-full py-4 border border-white/20 text-[10px] uppercase tracking-[0.3em] font-bold text-white hover:bg-white hover:text-black transition-all duration-500">
        Adquirir Club
    </button>
</div>